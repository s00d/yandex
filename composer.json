{
	"name": "s00d/yandex",
	"description": "PHP SDK для работы с некоторыми сервисами яндекса (Яндекс.Диск, Yandex.Disk)",
	"keywords": ["yandex", "disk", "диск", "яндекс", "php", "curl", "api", "client", "sdk",
		"yandex disk", "яндекс диск", "rest", "restful", "яндекс"
	],
	"license": "MIT",
	"authors": [{
		"name": "Dmitry Arhitector",
		"email": "dmitry.arhitector@yandex.ru"
	}],
	"require": {
		"php": "^8.1",
		"laminas/laminas-diactoros": "^3.0",
		"php-http/curl-client": "^2.2.1",
		"php-http/message": "^1.13.0",
		"php-http/message-factory": "^1.1",
		"php-http/client-common": "^2.5.0",
		"ext-curl": "*",
		"ext-json": "*"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5|^11.0"
	},
	"autoload": {
		"psr-4": {
			"Arhitector\\Yandex\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Arhitector\\Yandex\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit"
	},
	"extra": {
		"branch-alias": {
			"dev-master": "2.5-dev"
		}
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
